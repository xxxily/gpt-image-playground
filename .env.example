# GPT Image Playground environment example
# Copy this file to `.env.local` for local development, then fill in only the values you need.
# Never commit real API keys or passwords.

# -----------------------------------------------------------------------------
# Provider credentials
# -----------------------------------------------------------------------------

# OpenAI API key used by server proxy mode.
# You can leave this empty if every user configures their own key in the UI.
OPENAI_API_KEY=

# Custom OpenAI-compatible API base URL.
# Leave empty to use the official OpenAI endpoint.
# Official default: https://api.openai.com/v1
# Example third-party relay: https://your-relay.example.com/v1
OPENAI_API_BASE_URL=

# Google Gemini API key used by server proxy mode for Gemini image models.
# You can leave this empty if every user configures their own key in the UI.
GEMINI_API_KEY=

# Custom Gemini-compatible API base URL.
# Leave empty to use the official Gemini endpoint.
# Official default: https://generativelanguage.googleapis.com/v1beta
GEMINI_API_BASE_URL=

# SenseNova U1 Fast API key used by server proxy mode.
# Official default: https://token.sensenova.cn/v1
SENSENOVA_API_KEY=
SENSENOVA_API_BASE_URL=

# VolcEngine Ark / Seedream API key used by server proxy mode.
# Official default: https://ark.cn-beijing.volces.com/api/v3
SEEDREAM_API_KEY=
SEEDREAM_API_BASE_URL=

# Optional prompt-polishing model configuration. These values power the
# "润色" button through an OpenAI-compatible Chat Completions model.
# Leave empty to fall back to OPENAI_API_KEY / OPENAI_API_BASE_URL and the
# built-in model/prompt defaults.
POLISHING_API_KEY=
POLISHING_API_BASE_URL=
POLISHING_MODEL_ID=gpt-4o-mini
POLISHING_PROMPT=

# Optional thinking/reasoning controls for prompt polishing models.
# POLISHING_THINKING_ENABLED accepts true/false, enabled/disabled, 1/0.
# POLISHING_THINKING_EFFORT supports presets such as low/medium/high/max,
# and may also be any custom value supported by your compatible endpoint.
# POLISHING_THINKING_EFFORT_FORMAT:
# - openai    : sends thinking.type + reasoning_effort
# - anthropic : sends thinking.type + output_config.effort
# - both      : sends all fields for mixed-compatible routers
POLISHING_THINKING_ENABLED=false
POLISHING_THINKING_EFFORT=high
POLISHING_THINKING_EFFORT_FORMAT=openai

# -----------------------------------------------------------------------------
# Image storage
# -----------------------------------------------------------------------------

# Controls where generated image files are stored.
# Allowed values:
# - auto      : Vercel/preview deployments use IndexedDB, local/non-Vercel uses filesystem
# - fs        : save generated images to ./generated-images through the server
# - indexeddb : return base64 from /api/images and save images in browser IndexedDB
NEXT_PUBLIC_IMAGE_STORAGE_MODE=auto

# -----------------------------------------------------------------------------
# Connection/proxy protection
# -----------------------------------------------------------------------------

# When true/1/yes/on, non-official provider Base URLs are forced to client
# direct-link mode and `/api/images` refuses to proxy those service-site URLs.
# Recommended server-only variable.
CLIENT_DIRECT_LINK_PRIORITY=false

# Public alias for the same behavior. Usually leave empty and prefer
# CLIENT_DIRECT_LINK_PRIORITY unless your deployment platform requires a public flag.
NEXT_PUBLIC_CLIENT_DIRECT_LINK_PRIORITY=

# -----------------------------------------------------------------------------
# App access protection
# -----------------------------------------------------------------------------

# Optional app password for server-proxy requests.
# Direct client-link mode bypasses the server and therefore does not use this check.
APP_PASSWORD=

# -----------------------------------------------------------------------------
# Deployment/runtime hints
# -----------------------------------------------------------------------------

# Vercel sets this automatically. Local development normally leaves it empty.
# The server checks `VERCEL=1` to auto-select IndexedDB storage in auto mode.
VERCEL=

# Public Vercel environment hint used on the client in auto storage mode.
# Vercel may set this to production, preview, or development.
NEXT_PUBLIC_VERCEL_ENV=

# Docker/Next runtime settings. Usually set by Dockerfile or hosting platform.
PORT=3000
HOSTNAME=0.0.0.0
NODE_ENV=development

# Build-only flag used by `npm run build:desktop` to export a static desktop build.
# Normally leave unset; the script sets it automatically.
DESKTOP_BUILD=

# -----------------------------------------------------------------------------
# Analytics
# -----------------------------------------------------------------------------

# Optional Umami analytics script URL.
# Example: https://analytics.example.com/script.js
UMAMI_SCRIPT_URL=

# Optional Umami website ID. This value is emitted as the script's
# data-website-id attribute when UMAMI_SCRIPT_URL is also configured.
UMAMI_WEBSITE_ID=
