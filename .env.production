# Production defaults. Real Web requests should keep their own public domain as
# long as the reverse proxy forwards Host/X-Forwarded-Host and X-Forwarded-Proto.
OPENAI_API_BASE_URL=https://api.openai.com/v1
NEXT_PUBLIC_IMAGE_STORAGE_MODE=indexeddb

# 禁止非官方api走代理中转通道，减少对服务器带宽的压力限制
CLIENT_DIRECT_LINK_PRIORITY=true

UMAMI_SCRIPT_URL=https://msc.anzz.site/script.js
UMAMI_WEBSITE_ID=196a60e8-f1cd-43f6-b946-ccee0a8d7c7b

# AUTH_BASE_URL:
# - Not required for normal Web requests with forwarded host headers.
# - Used as the server-side fallback origin for auth when a request has no usable
#   Host/X-Forwarded-* headers or auth code runs without a Request object.
AUTH_BASE_URL=https://i.anzz.site

# NEXT_PUBLIC_SITE_URL:
# - Not required for normal Web short links; those use the actual request domain.
# - Used as the public default/fallback origin for browser and desktop builds.
NEXT_PUBLIC_SITE_URL=https://i.anzz.site

# NEXT_PUBLIC_APP_URL:
# - Not required for normal Web requests.
# - Kept as a secondary public fallback for code or deployments that still read
#   APP_URL naming. Keep it aligned with NEXT_PUBLIC_SITE_URL when configured.
NEXT_PUBLIC_APP_URL=https://i.anzz.site

# AUTH_TRUSTED_ORIGINS:
# - Not required for a single-domain deployment.
# - Add every alias that should share admin auth and short-link target trust.
# - Space or comma separated.
AUTH_TRUSTED_ORIGINS=https://img-playground.anzz.site https://i.anzz.site

ADMIN_DATABASE_PATH=~/work/gpt-image-playground/promo-admin.sqlite
PROMO_SHARE_CONFIG_ENABLED=true

NEXT_PUBLIC_GENERATION_HEADER_AD_ENABLED=false
NEXT_PUBLIC_GENERATION_HEADER_AD_IMAGE_URL=
NEXT_PUBLIC_GENERATION_HEADER_AD_LINK_URL=
NEXT_PUBLIC_GENERATION_HEADER_AD_ALT=
