# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# Tauri
src-tauri/target/
src-tauri/Cargo.lock
src-tauri/gen/
src-tauri/binaries/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# generated images
generated-images/

# local admin database
tmp/promo-admin.sqlite*

# local ad assets
public/ad/*
!public/ad/.gitkeep

# scripts/deploy.sh
scripts/*
!scripts/build-desktop.mjs
!scripts/sync-android-icons.mjs

.playwright-cli/
tmp-qa/
test-results/
.docs

graphify-out/
