{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "GPT Image Playground",
    "version": "2.8.2",
    "identifier": "com.gpt-image-playground.desktop",
    "build": {
        "frontendDist": "../out",
        "devUrl": "http://localhost:3000",
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build:desktop"
    },
    "app": {
        "windows": [
            {
                "title": "GPT Image Playground",
                "width": 1440,
                "height": 900,
                "resizable": true,
                "fullscreen": false
            }
        ],
        "security": {
            "csp": null,
            "assetProtocol": {
                "enable": true,
                "scope": ["$APPLOCALDATA/generated-images/**"]
            }
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
    },
    "plugins": {
        "updater": {
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY5NDAzN0Y4RTM2NjYwMkUKUldRdVlHYmorRGRBK1hVLzB1dGpXTGtQenIzdlFJT1VHc1Y2SUtZZG1ZWDF3OVh5WWt0b0hrV3EK",
            "endpoints": ["https://github.com/xxxily/gpt-image-playground/releases/latest/download/latest.json"]
        }
    }
}
