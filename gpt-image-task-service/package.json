{
    "name": "gpt-image-task-service",
    "version": "0.1.0-phase1",
    "private": true,
    "description": "Independent managed generation task service PoC for GPT Image Playground.",
    "type": "module",
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "dev": "node --watch dist/index.js",
        "start": "node dist/index.js",
        "test": "npm run build && node --test dist/__tests__/*.test.js",
        "smoke": "npm run build && node dist/smoke.js",
        "phase6:drill": "npm run build && node dist/phase6-drill.js",
        "hatchet:probe": "npm run build && node dist/hatchet/probe.js",
        "hatchet:worker": "npm run build && node dist/hatchet/worker.js",
        "hatchet:run": "npm run build && node dist/hatchet/run.js",
        "hatchet:live-smoke": "npm run build && node dist/hatchet/live-smoke.js",
        "hatchet:live-verify": "npm run build && node dist/hatchet/live-verify.js"
    },
    "dependencies": {
        "@grpc/grpc-js": "^1.14.3",
        "@hatchet-dev/typescript-sdk": "1.23.1",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/node": "^20.19.41",
        "typescript": "^5.9.3"
    },
    "engines": {
        "node": ">=20.0.0"
    }
}
