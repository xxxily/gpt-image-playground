{
    "name": "gpt-image-playground",
    "version": "2.15.0",
    "private": true,
    "author": "Blaze",
    "homepage": "https://img-playground.anzz.site",
    "repository": {
        "type": "git",
        "url": "https://github.com/xxxily/gpt-image-playground"
    },
    "scripts": {
        "dev": "next dev --turbopack",
        "build": "next build",
        "build:desktop": "node scripts/build-desktop.mjs",
        "tauri": "tauri",
        "tauri:dev": "tauri dev",
        "tauri:build": "tauri build",
        "android:init": "tauri android init",
        "android:dev": "tauri android dev",
        "sync:android-icons": "node scripts/sync-android-icons.mjs",
        "prebuild:android": "npm run sync:android-icons",
        "build:android": "tauri android build --apk",
        "start": "next start",
        "lint": "eslint src",
        "typecheck": "tsc -p tsconfig.typecheck.json --noEmit --pretty false",
        "format": "prettier --write \"src/**/*.{ts,tsx}\"",
        "test": "vitest run",
        "test:watch": "vitest",
        "audit:prod": "npm audit --omit=dev --audit-level=high",
        "clean": "node scripts/clean.mjs",
        "clean:deep": "node scripts/clean.mjs --deep",
        "secret-scan": "node scripts/secret-scan.mjs",
        "secret-scan:untracked": "node scripts/secret-scan.mjs --include-untracked",
        "release:env-check": "node scripts/secret-scan.mjs --check-env-presence --fail-on-tracked-env",
        "rust:test": "cargo test --manifest-path src-tauri/Cargo.toml",
        "rust:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
        "rust:audit": "cargo audit --file src-tauri/Cargo.lock",
        "rust:quality": "npm run rust:test && npm run rust:clippy && npm run rust:audit"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1060.0",
        "@aws-sdk/s3-request-presigner": "^3.1060.0",
        "@better-auth/drizzle-adapter": "^1.6.10",
        "@radix-ui/react-checkbox": "^1.3.3",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-popover": "^1.1.15",
        "@radix-ui/react-radio-group": "^1.3.8",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-slider": "^1.3.6",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-tabs": "^1.1.13",
        "@radix-ui/react-toggle": "^1.1.10",
        "@radix-ui/react-toggle-group": "^1.1.11",
        "@radix-ui/react-tooltip": "^1.2.8",
        "@tailwindcss/vite": "^4.3.0",
        "@tanstack/react-virtual": "^3.14.2",
        "@tauri-apps/api": "2.11.0",
        "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
        "@tauri-apps/plugin-opener": "^2.5.4",
        "@tauri-apps/plugin-process": "^2.3.1",
        "@tauri-apps/plugin-updater": "^2.10.1",
        "better-auth": "^1.6.10",
        "better-sqlite3": "^12.10.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "dexie": "^4.4.3",
        "dexie-react-hooks": "^1.1.7",
        "disable-devtool": "^0.3.9",
        "drizzle-orm": "^0.45.2",
        "lucide-react": "^0.503.0",
        "mime-types": "^3.0.2",
        "next": "^16.2.7",
        "next-themes": "^0.4.6",
        "openai": "^6.41.0",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "tailwind-merge": "^3.6.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.3.0",
        "@tauri-apps/cli": "^2.11.2",
        "@trivago/prettier-plugin-sort-imports": "^5.2.2",
        "@types/better-sqlite3": "^7.6.13",
        "@types/mime-types": "^3.0.1",
        "@types/node": "^20.19.41",
        "@types/react": "^19.2.16",
        "@types/react-dom": "^19.2.3",
        "cross-env": "^10.1.0",
        "eslint": "^9",
        "eslint-config-next": "^16.2.7",
        "prettier": "^3.8.3",
        "prettier-plugin-tailwindcss": "^0.6.14",
        "tailwindcss": "^4.3.0",
        "tw-animate-css": "^1.4.0",
        "typescript": "^5.9.3",
        "vitest": "^4.1.8"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "overrides": {
        "postcss": "^8.5.15",
        "brace-expansion": "^1.1.14",
        "@better-auth/core": "1.6.10",
        "@better-auth/utils": "0.4.0"
    },
    "optionalDependencies": {
        "@emnapi/core": "^1.4.3",
        "@emnapi/runtime": "^1.7.1",
        "@emnapi/wasi-threads": "^1.0.2",
        "@napi-rs/wasm-runtime": "^0.2.9",
        "@tybys/wasm-util": "^0.9.0"
    }
}
